{
  "cesp_version": "1.0",
  "name": "stronghold-frederick",
  "display_name": "Emperor Frederick (Stronghold Crusader)",
  "version": "1.0.0",
  "author": { "name": "Marko Jevic", "github": "koyev" },
  "license": "fair-use",
  "language": "en",
  "categories": {
    "session.start": {
      "sounds": [
        { "file": "sounds/fr_add_player_01.wav", "label": "At last" }
      ]
    },
    "task.acknowledge": {
      "sounds": [
        { "file": "sounds/fr_willattack_01.wav", "label": "Good plan" },
        { "file": "sounds/fr_sent_01.wav", "label": "Supplies have been sent" },
        { "file": "sounds/fr_siege_01.wav", "label": "My army is ready" }
      ]
    },
    "task.complete": {
      "sounds": [
        { "file": "sounds/fr_vict_01.wav", "label": "Troops fall before the Empire" },
        { "file": "sounds/fr_vict_02.wav", "label": "Strength to strength" },
        { "file": "sounds/fr_boast_01.wav", "label": "Vanquished an enemy" }
      ]
    },
    "task.error": {
      "sounds": [
        { "file": "sounds/fr_anger_01.wav", "label": "Siege is lost" },
        { "file": "sounds/fr_anger_02.wav", "label": "My castle crumbles" }
      ]
    },
    "input.required": {
      "sounds": [
        { "file": "sounds/fr_help_01.wav", "label": "Need reinforcements" },
        { "file": "sounds/fr_req_01.wav", "label": "Empire has need" }
      ]
    },
    "resource.limit": {
      "sounds": [
        { "file": "sounds/fr_notsent_01.wav", "label": "Cannot send supplies" },
        { "file": "sounds/fr_nohelp_01.wav", "label": "No troops to send" }
      ]
    },
    "user.spam": {
      "sounds": [
        { "file": "sounds/fr_noattack_01.wav", "label": "This is madness" },
        { "file": "sounds/fr_noattack_02.wav", "label": "Does not fit my plans" },
        { "file": "sounds/fr_kick_player_01.wav", "label": "No!" }
      ]
    }
  }
}
